# --- REACT & NODE ---
# Dependencias (se instalan con npm install o yarn)
node_modules/
/jspm_packages/

# Carpeta de construcción / producción
/build
/dist
/out
/.next/

# Logs de error y debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- UIKIT & STYLES ---
# Archivos de mapas para CSS/JS (opcional)
*.css.map
*.js.map
*.sass.map
*.scss.map

# Cache de herramientas de estilos
.stylelintcache
.eslintcache

# --- SEGURIDAD (VARS DE ENTORNO) ---
# NUNCA subas estos archivos a GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.json

# --- SISTEMA Y EDITORES ---
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# VS Code (Se ignoran configuraciones personales)
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json

# IntelliJ / WebStorm
.idea/
*.iws
*.iml
*.ipr

# --- OTROS ---
# Cobertura de tests
/coverage

# Archivos temporales
*.swp
*.bak
*.tmp
